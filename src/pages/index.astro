---
import '../styles/global.css';
import { getCollection } from 'astro:content';

const cartaEntries = await getCollection('carta');
// Opcional: ordenar por algún criterio si es necesario
const tapas = cartaEntries.map(entry => entry.data);

const galleryItems = [
	{ label: "Interior", id: "gallery-interior" },
	{ label: "Comida", id: "gallery-comida" },
	{ label: "Bebidas", id: "gallery-bebidas" }
];
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Bar El Sello | El Escorial - Tradición y Sabor Rústico</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;700&family=Inter:wght@300;400;600&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-stone-50 text-stone-800 selection:bg-orange-200">
		<!-- Header / Navigation -->
		<nav class="fixed top-0 w-full z-50 bg-stone-50/90 backdrop-blur-md border-b border-stone-200">
			<div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
				<div class="flex items-center gap-3">
					<!-- Logo Placeholder -->
					<div class="w-12 h-12 bg-stone-200 rounded-lg flex items-center justify-center overflow-hidden border border-stone-300">
						<img src="" alt="Logo" class="w-full h-full object-cover hidden" id="logo-img" />
						<span class="text-stone-400 text-xs font-bold">LOGO</span>
					</div>
					<span class="font-serif text-2xl font-bold tracking-tight text-stone-900">EL SELLO</span>
				</div>
				<div class="hidden md:flex gap-8 text-sm font-semibold uppercase tracking-wider text-stone-600">
					<a href="#inicio" class="hover:text-amber-700 transition-colors">Inicio</a>
					<a href="#carta" class="hover:text-amber-700 transition-colors">La Carta</a>
					<a href="#ambiente" class="hover:text-amber-700 transition-colors">Ambiente</a>
					<a href="#horarios" class="hover:text-amber-700 transition-colors">Contacto</a>
				</div>
			</div>
		</nav>

		<!-- Hero Section -->
		<section id="inicio" class="relative min-h-[90vh] flex flex-col justify-center items-center px-6 pt-20 text-white overflow-hidden bg-stone-800">
			<!-- Provisonal background style, ready for real image -->
			<div 
				class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat transition-opacity duration-1000" 
				style="background-image: url('https://images.unsplash.com/photo-1514933651103-005eec06c04b?q=80&w=2000&auto=format&fit=crop'); opacity: 0.6;"
			></div>
			<!-- Dark Overlay -->
			<div class="absolute inset-0 bg-stone-900/60 z-10"></div>

			<div class="relative z-20 text-center max-w-4xl px-4">
				<span class="inline-block text-amber-200 uppercase tracking-[0.4em] font-bold text-xs mb-6">Taberna Tradicional</span>
				<h1 class="font-serif text-5xl md:text-8xl font-bold mb-8 tracking-tight leading-tight">
					Bar El Sello <br/><span class="italic font-normal serif-alt text-amber-200">Tradición en El Escorial</span>
				</h1>
				<p class="text-lg md:text-2xl text-stone-200 mb-10 max-w-2xl mx-auto leading-relaxed font-light">
					Un espacio rústico y acogedor dedicado a las raciones caseras, el hierro forjado y el buen vino.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href="#carta" class="px-10 py-5 bg-amber-700 hover:bg-amber-800 text-white font-bold rounded-sm transition-all shadow-xl active:scale-95 text-center uppercase tracking-widest text-sm">
						Ver la Carta
					</a>
					<a href="#horarios" class="px-10 py-5 bg-white/10 hover:bg-white/20 text-white font-bold rounded-sm border border-white/30 backdrop-blur-md transition-all active:scale-95 text-center uppercase tracking-widest text-sm">
						Cómo Llegar
					</a>
				</div>
			</div>
		</section>

		<!-- Ambiente / Galería Section -->
		<section id="ambiente" class="py-24 px-6 bg-stone-100 border-y border-stone-200">
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-16">
					<h2 class="font-serif text-4xl md:text-5xl font-bold text-stone-900 mb-4">Nuestro Ambiente</h2>
					<p class="text-stone-500 font-light max-w-xl mx-auto">Detalles de madera, ladrillo visto y el calor de una taberna clásica.</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					{galleryItems.map((item) => (
						<div class="group relative aspect-square bg-stone-300 overflow-hidden rounded-sm border-4 border-white shadow-md">
							<div class="absolute inset-0 bg-stone-800/20 group-hover:bg-transparent transition-all duration-500"></div>
							<div class="w-full h-full flex items-center justify-center text-stone-100 font-serif italic text-2xl">
								{item.label}
							</div>
							<img src="" alt={item.label} class="absolute inset-0 w-full h-full object-cover hidden" />
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Info Section: Horarios y Ubicación -->
		<section id="horarios" class="py-24 px-6 bg-stone-50">
			<div class="max-w-6xl mx-auto">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
					<!-- Horarios & Info -->
					<div class="p-10 bg-white border border-stone-200 shadow-sm rounded-sm">
						<h2 class="font-serif text-3xl font-bold mb-8 text-stone-900">Horarios y Datos</h2>
						<ul class="space-y-4 text-stone-600 mb-10">
							<li class="flex justify-between border-b border-stone-100 pb-2">
								<span class="font-medium">Lunes a Jueves</span>
								<span>12:30 – 16:30 | 19:30 – 23:30</span>
							</li>
							<li class="flex justify-between border-b border-stone-100 pb-2 font-bold text-amber-900">
								<span>Viernes y Sábado</span>
								<span>12:30 – 00:00 (Ininterrumpido)</span>
							</li>
							<li class="flex justify-between pb-2 text-stone-400 italic">
								<span>Domingo</span>
								<span>Cerrado</span>
							</li>
						</ul>
						
						<h3 class="font-bold text-stone-900 mb-4 uppercase tracking-widest text-xs">A destacar</h3>
						<ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm text-stone-600">
							<li class="flex items-center gap-2">
								<span class="text-amber-700">✓</span> Comidas y Cenas
							</li>
							<li class="flex items-center gap-2">
								<span class="text-amber-700">✓</span> Servicio de mesa
							</li>
							<li class="flex items-center gap-2">
								<span class="text-amber-700">✓</span> Aceptamos tarjetas
							</li>
							<li class="flex items-center gap-2">
								<span class="text-amber-700">✓</span> Producto local
							</li>
						</ul>
					</div>

					<!-- Ubicación -->
					<div>
						<span class="text-amber-700 uppercase tracking-widest text-xs font-bold mb-4 block">Ubicación Real</span>
						<h2 class="font-serif text-4xl font-bold mb-6 text-stone-900">Visítanos en El Escorial</h2>
						<p class="text-lg text-stone-500 mb-8 leading-relaxed font-light">
							Calle de las Peregrinas 21,<br/>
							28280 El Escorial, Madrid, España.
						</p>
						<div class="flex flex-col gap-6">
							<div class="flex items-center gap-4">
								<div class="w-12 h-12 rounded-full bg-amber-100 flex items-center justify-center text-amber-800 border border-amber-200">
									📍
								</div>
								<span class="text-stone-700 font-medium italic">En el corazón histórico de la villa.</span>
							</div>
							<a 
								href="https://www.google.com/maps/search/?api=1&query=Bar+El+Sello+Calle+de+las+Peregrinas+21+El+Escorial" 
								target="_blank" 
								class="inline-block px-8 py-4 bg-stone-800 hover:bg-stone-900 text-white font-bold rounded-sm transition-all text-center uppercase tracking-widest text-xs"
							>
								Ver en Google Maps →
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Menu Section: La Carta -->
		<section id="carta" class="py-24 px-6 bg-orange-50/20">
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-16">
					<h2 class="font-serif text-5xl font-bold text-stone-900 mb-4">La Carta de El Sello</h2>
					<div class="w-16 h-1 bg-amber-700 mx-auto mb-8"></div>
					<p class="text-stone-500 max-w-xl mx-auto font-light italic">Recetas tradicionales con el toque de siempre.</p>
				</div>

				<!-- Grid Menu -->
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					{tapas.map((tapa) => (
						<article class="group bg-white border border-stone-200 p-8 rounded-sm shadow-sm hover:shadow-md hover:border-amber-200 transition-all duration-300">
							<div class="flex justify-between items-start mb-4">
								<h3 class="font-serif text-2xl font-bold text-stone-900 group-hover:text-amber-800 transition-colors">
									{tapa.title}
								</h3>
								<span class="text-stone-900 font-bold font-serif text-lg">
									{tapa.price}€
								</span>
							</div>
							<p class="text-stone-500 text-sm leading-relaxed font-light line-clamp-3">
								{tapa.description}
							</p>
							<div class="mt-6 pt-4 border-t border-stone-50 flex justify-between items-center">
								<span class="text-[10px] uppercase tracking-widest font-bold text-stone-400">{tapa.category}</span>
								<div class="w-1.5 h-1.5 rounded-full bg-amber-700 opacity-0 group-hover:opacity-100 transition-opacity"></div>
							</div>
						</article>
					))}
				</div>
			</div>
		</section>

		<!-- Footer -->
		<footer class="py-16 bg-stone-900 text-stone-400 px-6">
			<div class="max-w-6xl mx-auto flex flex-col items-center">
				<span class="font-serif text-3xl font-bold tracking-tighter text-white mb-6 uppercase">EL SELLO</span>
				<nav class="flex gap-8 mb-8 text-xs font-bold uppercase tracking-widest">
					<a href="#inicio" class="hover:text-white transition-colors">Inicio</a>
					<a href="#carta" class="hover:text-white transition-colors">Carta</a>
					<a href="#horarios" class="hover:text-white transition-colors">Ubicación</a>
				</nav>
				<p class="text-stone-500 text-[10px] tracking-[0.2em] uppercase">© 2026 Bar El Sello | Calle de las Peregrinas 21, El Escorial</p>
			</div>
		</footer>

		<style is:global>
			html {
				font-family: 'Inter', system-ui, sans-serif;
				scroll-behavior: smooth;
			}
			h1, h2, h3, .font-serif {
				font-family: 'Crimson Pro', serif;
			}
			.serif-alt {
				font-family: 'Playfair Display', serif;
			}
		</style>
	</body>
</html>
