import '../styles/global.css';
import { getCollection, getEntry } from 'astro:content';

const cartaEntries = await getCollection('carta');
// Opcional: ordenar por algún criterio si es necesario
const tapas = cartaEntries.map(entry => entry.data);

// Obtener configuración general (logo, galería, etc)
const configEntry = await getEntry('settings', 'general');
const siteConfig = configEntry?.data || {
	logo: "",
	siteName: "EL SELLO",
	heroImage: "https://images.unsplash.com/photo-1514933651103-005eec06c04b?q=80&w=2000&auto=format&fit=crop",
	gallery: [
		{ label: "Interior", image: "" },
		{ label: "Comida", image: "" },
		{ label: "Bebidas", image: "" }
	]
};

const galleryItems = siteConfig.gallery;
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Bar El Sello | El Escorial - Tradición y Sabor Rústico</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;700&family=Inter:wght@300;400;600&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-stone-50 text-stone-800 selection:bg-orange-200">
		<!-- Header / Navigation -->
		<nav class="fixed top-0 w-full z-50 bg-stone-50/90 backdrop-blur-md border-b border-stone-200">
			<div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
				<div class="flex items-center gap-3">
					<!-- Logo -->
					<div class="w-12 h-12 bg-stone-200 rounded-lg flex items-center justify-center overflow-hidden border border-stone-300">
						{siteConfig.logo ? (
							<img src={siteConfig.logo} alt={siteConfig.siteName} class="w-full h-full object-cover" id="logo-img" />
						) : (
							<span class="text-stone-400 text-xs font-bold uppercase tracking-tighter">EL SELLO</span>
						)}
					</div>
					<span class="font-serif text-2xl font-bold tracking-tight text-stone-900">{siteConfig.siteName}</span>
				</div>
				<div class="hidden md:flex gap-8 text-sm font-semibold uppercase tracking-wider text-stone-600">
					<a href="#inicio" class="hover:text-amber-700 transition-colors">Inicio</a>
					<a href="#carta" class="hover:text-amber-700 transition-colors">La Carta</a>
					<a href="#ambiente" class="hover:text-amber-700 transition-colors">Ambiente</a>
					<a href="#horarios" class="hover:text-amber-700 transition-colors">Contacto</a>
				</div>
			</div>
		</nav>

		<!-- Hero Section -->
		<section id="inicio" class="relative min-h-[90vh] flex flex-col justify-center items-center px-6 pt-20 text-white overflow-hidden bg-stone-800">
			<!-- Background with CMS image -->
			<div 
				class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat transition-opacity duration-1000" 
				style={`background-image: url('${siteConfig.heroImage}'); opacity: 0.6;`}
			></div>
			<!-- Dark Overlay -->
			<div class="absolute inset-0 bg-stone-900/60 z-10"></div>

			<div class="relative z-20 text-center max-w-4xl px-4">
				<span class="inline-block text-amber-200 uppercase tracking-[0.4em] font-bold text-xs mb-6">Taberna Tradicional</span>
				<h1 class="font-serif text-5xl md:text-8xl font-bold mb-8 tracking-tight leading-tight">
					{siteConfig.siteName} <br/><span class="italic font-normal serif-alt text-amber-200">Tradición en El Escorial</span>
				</h1>
				<p class="text-lg md:text-2xl text-stone-200 mb-10 max-w-2xl mx-auto leading-relaxed font-light">
					Un espacio rústico y acogedor dedicado a las raciones caseras, el hierro forjado y el buen vino.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href="#carta" class="px-10 py-5 bg-amber-700 hover:bg-amber-800 text-white font-bold rounded-sm transition-all shadow-xl active:scale-95 text-center uppercase tracking-widest text-sm">
						Ver la Carta
					</a>
					<a href="#horarios" class="px-10 py-5 bg-white/10 hover:bg-white/20 text-white font-bold rounded-sm border border-white/30 backdrop-blur-md transition-all active:scale-95 text-center uppercase tracking-widest text-sm">
						Cómo Llegar
					</a>
				</div>
			</div>
		</section>

		<!-- Ambiente / Galería Section -->
		<section id="ambiente" class="py-24 px-6 bg-stone-100 border-y border-stone-200">
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-16">
					<h2 class="font-serif text-4xl md:text-5xl font-bold text-stone-900 mb-4">Nuestro Ambiente</h2>
					<p class="text-stone-500 font-light max-w-xl mx-auto">Detalles de madera, ladrillo visto y el calor de una taberna clásica.</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					{galleryItems.map((item) => (
						<div class="group relative aspect-square bg-stone-300 overflow-hidden rounded-sm border-4 border-white shadow-md">
							<div class="absolute inset-0 bg-stone-800/20 group-hover:bg-transparent transition-all duration-500 z-10"></div>
							<div class="absolute inset-0 w-full h-full flex items-center justify-center text-stone-100 font-serif italic text-2xl z-20 pointer-events-none group-hover:opacity-0 transition-opacity">
								{!item.image && <span>{item.label}</span>}
							</div>
							{item.image ? (
								<img src={item.image} alt={item.label} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
							) : (
								<div class="w-full h-full bg-stone-200"></div>
							)}
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Info Section: Horarios y Ubicación -->
		<section id="horarios" class="py-24 px-6 bg-stone-50">
			<div class="max-w-6xl mx-auto">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
					<!-- Horarios & Info -->
					<div class="p-10 bg-white border border-stone-200 shadow-sm rounded-sm">
						<h2 class="font-serif text-3xl font-bold mb-8 text-stone-900">Horarios y Datos</h2>
						<ul class="space-y-4 text-stone-600 mb-10">
							<li class="flex justify-between border-b border-stone-100 pb-2">
								<span class="font-medium">Lunes a Jueves</span>
								<span>12:30 – 16:30 | 19:30 – 23:30</span>
							</li>
							<li class="flex justify-between border-b border-stone-100 pb-2 font-bold text-amber-900">
								<span>Viernes y Sábado</span>
								<span>12:30 – 00:00 (Ininterrumpido)</span>
							</li>
							<li class="flex justify-between pb-2 text-stone-400 italic">
								<span>Domingo</span>
								<span>Cerrado</span>
							</li>
						</ul>
						
						<h3 class="font-bold text-stone-900 mb-4 uppercase tracking-widest text-xs">A destacar</h3>
						<ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm text-stone-600">
							<li class="flex items-center gap-2">
								<span class="text-amber-700">✓</span> Comidas y Cenas
							</li>
							<li class="flex items-center gap-2">
								<span class="text-amber-700">✓</span> Servicio de mesa
							</li>
							<li class="flex items-center gap-2">
								<span class="text-amber-700">✓</span> Aceptamos tarjetas
							</li>
							<li class="flex items-center gap-2">
								<span class="text-amber-700">✓</span> Producto local
							</li>
						</ul>
					</div>

					<!-- Ubicación -->
					<div class="space-y-8">
						<div>
							<span class="text-amber-700 uppercase tracking-widest text-xs font-bold mb-2 block">Ubicación Real</span>
							<h2 class="font-serif text-4xl font-bold mb-4 text-stone-900">Visítanos en El Escorial</h2>
							<p class="text-lg text-stone-500 mb-6 leading-relaxed font-light">
								Calle de las Peregrinas 21,<br/>
								28280 El Escorial, Madrid, España.
							</p>
						</div>

						<!-- Google Maps Iframe -->
						<div class="w-full aspect-video rounded-sm overflow-hidden border border-stone-200 shadow-inner grayscale-[0.5] hover:grayscale-0 transition-all duration-700">
							<iframe 
								src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3032.544747!2d-4.126435!3d40.584766!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd4177d61c6b6b7b%3A0x6b6b7b6b7b6b7b6b!2sCalle%20de%20las%20Peregrinas%2C%2021%2C%2028280%20El%20Escorial%2C%20Madrid!5e0!3m2!1ses!2ses!4v1710345678901!5m2!1ses!2ses" 
								width="100%" 
								height="100%" 
								style="border:0;" 
								allowfullscreen="" 
								loading="lazy" 
								referrerpolicy="no-referrer-when-downgrade"
							></iframe>
						</div>

						<div class="flex flex-col gap-4">
							<a 
								href="https://www.google.com/maps/search/?api=1&query=Bar+El+Sello+Calle+de+las+Peregrinas+21+El+Escorial" 
								target="_blank" 
								class="inline-block px-8 py-4 bg-stone-800 hover:bg-stone-900 text-white font-bold rounded-sm transition-all text-center uppercase tracking-widest text-xs"
							>
								Abrir en Google Maps →
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Menu Section: La Carta -->
		<section id="carta" class="py-24 px-6 bg-orange-50/20">
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-16">
					<h2 class="font-serif text-5xl font-bold text-stone-900 mb-4">La Carta de El Sello</h2>
					<div class="w-16 h-1 bg-amber-700 mx-auto mb-8"></div>
					<p class="text-stone-500 max-w-xl mx-auto font-light italic">Recetas tradicionales con el toque de siempre.</p>
				</div>

				<!-- Grid Menu -->
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					{tapas.map((tapa) => (
						<article class="group bg-white border border-stone-200 p-8 rounded-sm shadow-sm hover:shadow-md hover:border-amber-200 transition-all duration-300">
							<div class="flex justify-between items-start mb-4">
								<h3 class="font-serif text-2xl font-bold text-stone-900 group-hover:text-amber-800 transition-colors">
									{tapa.title}
								</h3>
								<span class="text-stone-900 font-bold font-serif text-lg">
									{tapa.price}€
								</span>
							</div>
							<p class="text-stone-500 text-sm leading-relaxed font-light line-clamp-3">
								{tapa.description}
							</p>
							<div class="mt-6 pt-4 border-t border-stone-50 flex justify-between items-center">
								<span class="text-[10px] uppercase tracking-widest font-bold text-stone-400">{tapa.category}</span>
								<div class="w-1.5 h-1.5 rounded-full bg-amber-700 opacity-0 group-hover:opacity-100 transition-opacity"></div>
							</div>
						</article>
					))}
				</div>
			</div>
		</section>

		<!-- Testimonios / Opiniones Section -->
		<section id="opiniones" class="py-24 px-6 bg-stone-900 text-white overflow-hidden relative">
			<!-- Subtle rustic texture background could go here -->
			<div class="max-w-6xl mx-auto relative z-10">
				<div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
					<div class="max-w-2xl">
						<span class="text-amber-400 uppercase tracking-[0.3em] text-xs font-bold mb-4 block">Experiencias</span>
						<h2 class="font-serif text-4xl md:text-5xl font-bold leading-tight">Lo que dicen nuestros <span class="italic text-amber-200">comensales</span></h2>
					</div>
					<a href="https://www.google.com/maps/search/?api=1&query=Bar+El+Sello+Calle+de+las+Peregrinas+21+El+Escorial" target="_blank" class="text-amber-200 hover:text-white transition-colors flex items-center gap-2 border-b border-amber-200/30 pb-1 text-sm font-semibold uppercase tracking-wider">
						Ver todas en Google 
						<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
						</svg>
					</a>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<!-- Opinión 1 -->
					<div class="bg-white/5 p-8 rounded-sm border border-white/10 backdrop-blur-sm">
						<div class="flex gap-1 text-amber-400 mb-6">
							{"★".repeat(5)}
						</div>
						<p class="text-stone-300 italic mb-8 leading-relaxed font-light">"Increíble tortilla de patatas, de las mejores del pueblo. El ambiente rústico te hace sentir como en casa. ¡Repetiremos seguro!"</p>
						<div class="flex items-center gap-4">
							<div class="w-10 h-10 rounded-full bg-stone-700 flex items-center justify-center font-bold text-stone-300">JP</div>
							<cite class="not-italic font-bold text-stone-100 flex flex-col">
								Juan Pérez
								<span class="text-[10px] text-stone-500 font-normal uppercase tracking-widest mt-1">Local Guide</span>
							</cite>
						</div>
					</div>

					<!-- Opinión 2 -->
					<div class="bg-white/5 p-8 rounded-sm border border-white/10 backdrop-blur-sm">
						<div class="flex gap-1 text-amber-400 mb-6">
							{"★".repeat(5)}
						</div>
						<p class="text-stone-300 italic mb-8 leading-relaxed font-light">"Un sitio con mucho encanto. Las raciones son abundantes y el servicio es de 10. Muy recomendable si visitas El Escorial."</p>
						<div class="flex items-center gap-4">
							<div class="w-10 h-10 rounded-full bg-stone-700 flex items-center justify-center font-bold text-stone-300">MG</div>
							<cite class="not-italic font-bold text-stone-100 flex flex-col">
								Marta García
								<span class="text-[10px] text-stone-500 font-normal uppercase tracking-widest mt-1">Visitante</span>
							</cite>
						</div>
					</div>

					<!-- Opinión 3 -->
					<div class="bg-white/5 p-8 rounded-sm border border-white/10 backdrop-blur-sm">
						<div class="flex gap-1 text-amber-400 mb-6">
							{"★".repeat(5)}
						</div>
						<p class="text-stone-300 italic mb-8 leading-relaxed font-light">"Vinos de calidad y picoteo excelente. El local es precioso, con mucha personalidad tradicional."</p>
						<div class="flex items-center gap-4">
							<div class="w-10 h-10 rounded-full bg-stone-700 flex items-center justify-center font-bold text-stone-300">RL</div>
							<cite class="not-italic font-bold text-stone-100 flex flex-col">
								Ricardo López
								<span class="text-[10px] text-stone-500 font-normal uppercase tracking-widest mt-1">Comensal Habitual</span>
							</cite>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Footer -->
		<footer class="py-16 bg-stone-900 text-stone-400 px-6">
			<div class="max-w-6xl mx-auto flex flex-col items-center">
				<span class="font-serif text-3xl font-bold tracking-tighter text-white mb-6 uppercase">{siteConfig.siteName}</span>
				<nav class="flex gap-8 mb-8 text-xs font-bold uppercase tracking-widest">
					<a href="#inicio" class="hover:text-white transition-colors">Inicio</a>
					<a href="#carta" class="hover:text-white transition-colors">Carta</a>
					<a href="#horarios" class="hover:text-white transition-colors">Ubicación</a>
				</nav>
				<p class="text-stone-500 text-[10px] tracking-[0.2em] uppercase">© 2026 {siteConfig.siteName} | Calle de las Peregrinas 21, El Escorial</p>
			</div>
		</footer>

		<style is:global>
			html {
				font-family: 'Inter', system-ui, sans-serif;
				scroll-behavior: smooth;
			}
			h1, h2, h3, .font-serif {
				font-family: 'Crimson Pro', serif;
			}
			.serif-alt {
				font-family: 'Playfair Display', serif;
			}
		</style>
	</body>
</html>
